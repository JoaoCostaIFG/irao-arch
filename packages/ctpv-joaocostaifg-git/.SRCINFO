pkgbase = ctpv-joaocostaifg-git
	pkgdesc = Fast image previews for lf
	pkgver = r287.185b656
	pkgrel = 1
	url = https://github.com/JoaoCostaIFG/ctpv
	arch = i686
	arch = x86_64
	license = MIT
	makedepends = git
	depends = file
	depends = openssl
	optdepends = atool: for archive files
	optdepends = bat: for text files
	optdepends = chafa: for image files
	optdepends = colordiff: for diff files
	optdepends = diff-so-fancy: for diff files
	optdepends = elinks: for html files
	optdepends = f3d: for 3D model files
	optdepends = ffmpeg: for audio file metadata
	optdepends = ffmpegthumbnailer: for audio and video files
	optdepends = git-delta: for diff files
	optdepends = glow: for markdown files
	optdepends = gnupg: for gpg-encrypted files
	optdepends = highlight: for text files
	optdepends = imagemagick: for svg, webp and font files
	optdepends = isoinfo: for iso files
	optdepends = jq: for json and jupyter notebook files
	optdepends = jupyter-notebook: for jupyter notebook files
	optdepends = libreoffice-fresh: for office files
	optdepends = lynx: for html files
	optdepends = mdcat: for markdown files
	optdepends = ouch: for archive files
	optdepends = pandoc: for epub files
	optdepends = perl-image-exiftool: for any file metadata
	optdepends = poppler: for pdf files
	optdepends = source-highlight: for text files
	optdepends = sqlite: for sqlite database files
	optdepends = transmission-cli: for torrent files
	optdepends = unzip: for epub files (fallback if pandoc unavailable)
	optdepends = w3m: for html files
	provides = ctpv
	conflicts = ctpv
	conflicts = ctpv-fish
	source = git+https://github.com/JoaoCostaIFG/ctpv?signed
